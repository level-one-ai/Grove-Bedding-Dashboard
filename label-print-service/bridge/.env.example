# ─── Grove Bedding Label Bridge Agent — Environment Variables ───────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to GitHub.

# ── Firebase (same project as your Vercel backend) ──────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key exactly as shown in the service account JSON,
# replacing actual newlines with the literal string \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── DYMO Printer Settings ───────────────────────────────────────────────────
# Leave blank to auto-detect the first DYMO printer connected via USB
DYMO_PRINTER_NAME=

# Only needed if DYMO is installed in a non-standard location
# Windows default: C:\Program Files\DYMO\DYMO Connect\DymoPrint.exe
# Mac default:     /Library/Frameworks/DYMO.LabelWriter.SDK.framework/dymo-print
DYMO_CLI_PATH=

# ── Poll Settings ────────────────────────────────────────────────────────────
# How often to check Firestore for new print jobs (milliseconds)
POLL_INTERVAL_MS=5000

# How many times to retry a failed print job before giving up
MAX_RETRIES=3

# How long to wait before retrying a failed job (milliseconds)
RETRY_DELAY_MS=30000

# Optional — name for this bridge (shown in dashboard)
# Change if you have more than one office PC
BRIDGE_ID=office-windows-pc

# Heartbeat interval in milliseconds (default: 30 seconds)
HEARTBEAT_INTERVAL_MS=30000
