{
    "version": 2,
    "fluid": true,
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/scan-now",
            "schedule": "* * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/sales-orders",
            "destination": "/api/sales-orders.cjs"
        },
        {
            "source": "/api/set-etd",
            "destination": "/api/set-etd.cjs"
        },
        {
            "source": "/api/discover-fields",
            "destination": "/api/discover-fields.cjs"
        },
        {
            "source": "/api/webhook-cin7",
            "destination": "/api/webhook-cin7.cjs"
        },
        {
            "source": "/api/bridge-status",
            "destination": "/api/bridge-status.cjs"
        },
        {
            "source": "/api/dispatch-log",
            "destination": "/api/dispatch-log.cjs"
        },
        {
            "source": "/api/label-history",
            "destination": "/api/label-history.cjs"
        },
        {
            "source": "/api/spoke-plans",
            "destination": "/api/spoke-plans.cjs"
        },
        {
            "source": "/api/spoke-stops",
            "destination": "/api/spoke-stops.cjs"
        },
        {
            "source": "/api/birlea-confirm",
            "destination": "/api/birlea-confirm.cjs"
        },
        {
            "source": "/api/router-status",
            "destination": "/pdf-router-connection/api/router-status.cjs"
        },
        {
            "source": "/api/scans-list",
            "destination": "/api/scans-list.cjs"
        },
        {
            "source": "/api/reset-stuck-file",
            "destination": "/api/reset-stuck-file.cjs"
        },
        {
            "source": "/api/run-diag",
            "destination": "/api/run-diag.cjs"
        },
        {
            "source": "/api/reprocess-page",
            "destination": "/api/reprocess-page.cjs"
        },
        {
            "source": "/api/reprocess-file",
            "destination": "/api/reprocess-file.cjs"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        },
        {
            "source": "/api/cin7-po-fields",
            "destination": "/api/cin7-po-fields.cjs"
        },
        {
            "source": "/api/cin7-so-probe",
            "destination": "/api/cin7-so-probe.cjs"
        },
        {
            "source": "/api/cin7-crm-probe",
            "destination": "/api/cin7-crm-probe.cjs"
        },
        {
            "source": "/api/cin7-member-orders",
            "destination": "/api/cin7-member-orders.cjs"
        },
        {
            "source": "/api/cin7-field-probe",
            "destination": "/api/cin7-field-probe.cjs"
        }
    ],
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "api/*.cjs",
            "use": "@vercel/node"
        },
        {
            "src": "pdf-router/api/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "pdf-router-connection/api/*.cjs",
            "use": "@vercel/node"
        }
    ]
}
